# ---- AI provider: Google Gemini ----
# 1. Get a free key at https://aistudio.google.com/app/apikey
# 2. Copy this file to ".env"  (in this same folder)
# 3. Paste your key below, then run:  npm run dev
GEMINI_API_KEY=your-gemini-key-here

# Optional: pick a different Gemini model (default: gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-flash

# ---- Editing ----
# Password required to unlock in-app Markdown editing (viewing stays open).
EDIT_PASSWORD=change-me
# Secret used to sign edit-session tokens. Set to any long random string.
AUTH_SECRET=please-change-this-to-a-long-random-string
# Auto-commit each saved edit to git for version history (true/false).
GIT_AUTOCOMMIT=true

# Backend API port (Vite client proxies /api to this). Keep as 8787.
BACKEND_PORT=8787
